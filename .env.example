# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Email (SMTP / Nodemailer / Resend)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your_api_key_here
EMAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=your_admin_email@example.com

# Scraper Settings (Optional / Override database configuration)
# Specify Netscape/JSON cookie string or path to a cookies.txt file
INSTAGRAM_COOKIES=
# Extract cookies automatically from a browser (local development only: chrome, edge, firefox, brave, opera)
INSTAGRAM_COOKIES_BROWSER=
# Specify a proxy URL if the server IP is restricted
INSTAGRAM_PROXY=
